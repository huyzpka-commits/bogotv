<Window x:Class="BogoTV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BogoTV - Bo go Tieng Viet"
        Height="440" Width="480"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <Window.Resources>
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D5D8E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8EAF6"/>
                                <Setter Property="BorderBrush" Value="#7986CB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C5CAE9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource MainButton}">
            <Setter Property="Background" Value="#3F51B5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#303F9F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource MainButton}">
            <Setter Property="Background" Value="#E53935"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#C62828"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1A237E"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="Margin" Value="10,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="BogoTV" Style="{StaticResource HeaderStyle}" Margin="0,0,10,0"/>
                <TextBlock Text="v1.0.0" FontSize="12" Foreground="#90A4AE"
                           VerticalAlignment="Bottom" Margin="0,0,0,2"/>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="6"
                    BorderBrush="#E0E0E0" BorderThickness="1" Padding="12,10" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Bang ma:"
                               Style="{StaticResource LabelStyle}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1"
                               x:Name="cmbCodePage"
                               Style="{StaticResource ComboBoxStyle}"
                               SelectionChanged="cmbCodePage_SelectionChanged">
                        <ComboBoxItem Content="Unicode"/>
                        <ComboBoxItem Content="TCVN3"/>
                        <ComboBoxItem Content="VNI"/>
                        <ComboBoxItem Content="VPS"/>
                        <ComboBoxItem Content="VISCII"/>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Kieu go:"
                               Style="{StaticResource LabelStyle}"/>
                    <ComboBox Grid.Row="1" Grid.Column="1"
                               x:Name="cmbTypingMethod"
                               Style="{StaticResource ComboBoxStyle}"
                               SelectionChanged="cmbTypingMethod_SelectionChanged">
                        <ComboBoxItem Content="Telex"/>
                        <ComboBoxItem Content="VNI"/>
                        <ComboBoxItem Content="VIQR"/>
                    </ComboBox>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="6"
                    BorderBrush="#E0E0E0" BorderThickness="1" Padding="8,6" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Trang thai: " Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center"/>
                    <Ellipse x:Name="statusIndicator" Width="12" Height="12"
                             Fill="#4CAF50" Margin="4,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtStatus" Text="Dang hoat dong"
                               FontSize="14" FontFamily="Segoe UI"
                               Foreground="#4CAF50" VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <UniformGrid Grid.Row="3" Columns="4" Margin="0,0,0,4">
                <Button x:Name="btnClose" Content="Dong" Style="{StaticResource MainButton}"
                        Click="btnClose_Click"/>
                <Button x:Name="btnExit" Content="Ket thuc" Style="{StaticResource DangerButton}"
                        Click="btnExit_Click"/>
                <Button x:Name="btnExpand" Content="Mo rong" Style="{StaticResource MainButton}"
                        Click="btnExpand_Click"/>
                <Button x:Name="btnDefault" Content="Mac dinh" Style="{StaticResource MainButton}"
                        Click="btnDefault_Click"/>
            </UniformGrid>

            <UniformGrid Grid.Row="4" Columns="3" Margin="0,4,0,8">
                <Button x:Name="btnHelp" Content="Huong dan su dung" Style="{StaticResource MainButton}"
                        Click="btnHelp_Click"/>
                <Button x:Name="btnAbout" Content="Thong tin app" Style="{StaticResource MainButton}"
                        Click="btnAbout_Click"/>
                <Button x:Name="btnToggle" Content="Bat/Tat bo go" Style="{StaticResource PrimaryButton}"
                        Click="btnToggle_Click"/>
            </UniformGrid>

            <Border x:Name="advancedPanel" Grid.Row="5" Background="White"
                    CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1"
                    Padding="12,10" Margin="0,0,0,8" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Tuy chon nang cao" Style="{StaticResource HeaderStyle}"
                               FontSize="15" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Phim tat Bat/Tat: " Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="txtHotkey" Width="150" Height="28"
                                 FontSize="13" FontFamily="Segoe UI"
                                 VerticalContentAlignment="Center" Padding="4,0"
                                 Text="Ctrl + ." IsReadOnly="True"/>
                    </StackPanel>

                    <CheckBox x:Name="chkAutoStart" Content="Khoi dong cung Windows"
                              Style="{StaticResource CheckBoxStyle}"/>
                    <CheckBox x:Name="chkClipboard" Content="Su dung clipboard khi gui khong duoc"
                              Style="{StaticResource CheckBoxStyle}"/>
                    <CheckBox x:Name="chkBlockCapslock" Content="Chan phim Capslock"
                              Style="{StaticResource CheckBoxStyle}"/>
                    <CheckBox x:Name="chkShowOSK" Content="Hien thi ban phim ao"
                              Style="{StaticResource CheckBoxStyle}"/>

                    <TextBlock Text="Ghi chu: Phim tat Ctrl + . de bat/tat nhanh bo go."
                               FontSize="12" Foreground="#90A4AE"
                               FontFamily="Segoe UI" Margin="10,8,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="6" Text="BogoTV (c) 2026 - Bo go Tieng Viet cho Windows"
                       FontSize="11" Foreground="#B0BEC5"
                       FontFamily="Segoe UI" HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"/>
        </Grid>
    </Border>
</Window>
